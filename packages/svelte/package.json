  "scripts": {
    "build": "pnpm run clean && tsx ../../scripts/generate-icons.ts outlined svelte && tsx ../../scripts/generate-exports.ts outlined svelte && tsx ../../scripts/generate-icons.ts rounded svelte --target-package=svelte --output-subdir=rounded --skip-metadata && tsx ../../scripts/generate-exports.ts rounded svelte --target-package=svelte --output-subdir=rounded && tsx ../../scripts/generate-icons.ts sharp svelte --target-package=svelte --output-subdir=sharp --skip-metadata && tsx ../../scripts/generate-exports.ts sharp svelte --target-package=svelte --output-subdir=sharp && pnpm run build:lib",
    "build:dev": "pnpm run clean && NODE_ENV=development tsx ../../scripts/generate-icons.ts outlined svelte && tsx ../../scripts/generate-exports.ts outlined svelte && NODE_ENV=development tsx ../../scripts/generate-icons.ts rounded svelte --target-package=svelte --output-subdir=rounded --skip-metadata && tsx ../../scripts/generate-exports.ts rounded svelte --target-package=svelte --output-subdir=rounded && NODE_ENV=development tsx ../../scripts/generate-icons.ts sharp svelte --target-package=svelte --output-subdir=sharp --skip-metadata && tsx ../../scripts/generate-exports.ts sharp svelte --target-package=svelte --output-subdir=sharp && pnpm run build:lib",
    "build:lib": "svelte-package --input ./src --output ./dist && tsx ../../scripts/strip-jsdoc-comments.ts dist && mkdir -p dist && cp -R src/metadata dist/metadata",
    "clean": "rimraf dist src/icons src/rounded src/sharp src/metadata src/index.ts src/w*.ts",
    "test": "vitest run",
    "lint": "cd ../.. && eslint packages/svelte/src --ext .ts --report-unused-disable-directives-severity off"
  },
