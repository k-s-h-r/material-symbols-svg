    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm run clean && tsx ../../scripts/generate-icons.ts outlined react && tsx ../../scripts/generate-exports.ts outlined react && tsx ../../scripts/generate-icons.ts rounded react --target-package=react --output-subdir=rounded --skip-metadata && tsx ../../scripts/generate-exports.ts rounded react --target-package=react --output-subdir=rounded && tsx ../../scripts/generate-icons.ts sharp react --target-package=react --output-subdir=sharp --skip-metadata && tsx ../../scripts/generate-exports.ts sharp react --target-package=react --output-subdir=sharp && pnpm run build:lib && pnpm run build:types",
    "build:dev": "pnpm run clean && NODE_ENV=development tsx ../../scripts/generate-icons.ts outlined react && tsx ../../scripts/generate-exports.ts outlined react && NODE_ENV=development tsx ../../scripts/generate-icons.ts rounded react --target-package=react --output-subdir=rounded --skip-metadata && tsx ../../scripts/generate-exports.ts rounded react --target-package=react --output-subdir=rounded && NODE_ENV=development tsx ../../scripts/generate-icons.ts sharp react --target-package=react --output-subdir=sharp --skip-metadata && tsx ../../scripts/generate-exports.ts sharp react --target-package=react --output-subdir=sharp && pnpm run build:lib && pnpm run build:types",
    "build:lib": "NODE_OPTIONS=--max-old-space-size=12288 rollup -c",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "cd ../.. && eslint packages/react/src --ext .ts,.tsx --report-unused-disable-directives-severity off"
  },
  "keywords": [
    "react",
    "icons",
    "material-symbols",
    "typescript",
    "components",
    "svg"
  ],
  "author": "k-s-h-r",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/k-s-h-r/material-symbols-svg.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/k-s-h-r/material-symbols-svg/issues"
  },
  "homepage": "https://material-symbols-svg.com",
  "peerDependencies": {
    "react": "^16.5.1 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.37",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^25.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.59.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-esbuild": "^6.1.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
