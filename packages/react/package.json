      "types": "./dist/w400.d.ts",
      "import": "./dist/w400.js"
    },
    "./outlined/w100": {
      "types": "./dist/w100.d.ts",
      "import": "./dist/w100.js"
    },
    "./outlined/w200": {
      "types": "./dist/w200.d.ts",
      "import": "./dist/w200.js"
    },
    "./outlined/w300": {
      "types": "./dist/w300.d.ts",
      "import": "./dist/w300.js"
    },
    "./outlined/w400": {
      "types": "./dist/w400.d.ts",
      "import": "./dist/w400.js"
    },
    "./outlined/w500": {
      "types": "./dist/w500.d.ts",
      "import": "./dist/w500.js"
    },
    "./outlined/w600": {
      "types": "./dist/w600.d.ts",
