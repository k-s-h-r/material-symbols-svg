    },
    "./outlined/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js"
    },
    "./rounded": {
      "types": "./dist/rounded/w400.d.ts",
      "import": "./dist/rounded/w400.js"
    },
    "./rounded/w100": {
      "types": "./dist/rounded/w100.d.ts",
      "import": "./dist/rounded/w100.js"
    },
    "./rounded/w200": {
      "types": "./dist/rounded/w200.d.ts",
      "import": "./dist/rounded/w200.js"
    },
    "./rounded/w300": {
      "types": "./dist/rounded/w300.d.ts",
