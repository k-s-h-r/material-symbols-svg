    "./rounded/*": {
      "types": "./dist/rounded/icons/*.d.ts",
      "import": "./dist/rounded/icons/*.js"
    },
    "./sharp": {
      "types": "./dist/sharp/w400.d.ts",
      "import": "./dist/sharp/w400.js"
    },
    "./sharp/w100": {
