{
  "name": "@material-symbols-svg/astro",
  "version": "0.3.0",
  "description": "Material Symbols (Outlined) as Astro components",
  "type": "module",
  "main": "./dist/index.ts",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.ts"
    },
    "./w100": {
      "types": "./dist/w100.d.ts",
      "import": "./dist/w100.ts"
    },
    "./w200": {
      "types": "./dist/w200.d.ts",
      "import": "./dist/w200.ts"
    },
    "./w300": {
      "types": "./dist/w300.d.ts",
      "import": "./dist/w300.ts"
    },
    "./w400": {
      "types": "./dist/w400.d.ts",
      "import": "./dist/w400.ts"
    },
    "./w500": {
      "types": "./dist/w500.d.ts",
      "import": "./dist/w500.ts"
    },
    "./w600": {
      "types": "./dist/w600.d.ts",
      "import": "./dist/w600.ts"
    },
    "./w700": {
      "types": "./dist/w700.d.ts",
      "import": "./dist/w700.ts"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.ts"
    },
    "./*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.ts"
    },
    "./outlined": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.ts"
    },
    "./outlined/w100": {
      "types": "./dist/w100.d.ts",
      "import": "./dist/w100.ts"
    },
    "./outlined/w200": {
      "types": "./dist/w200.d.ts",
      "import": "./dist/w200.ts"
    },
    "./outlined/w300": {
      "types": "./dist/w300.d.ts",
      "import": "./dist/w300.ts"
    },
    "./outlined/w400": {
      "types": "./dist/w400.d.ts",
      "import": "./dist/w400.ts"
    },
    "./outlined/w500": {
      "types": "./dist/w500.d.ts",
      "import": "./dist/w500.ts"
    },
    "./outlined/w600": {
      "types": "./dist/w600.d.ts",
      "import": "./dist/w600.ts"
    },
    "./outlined/w700": {
      "types": "./dist/w700.d.ts",
      "import": "./dist/w700.ts"
    },
    "./outlined/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.ts"
    },
    "./outlined/icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run clean && tsx ../../scripts/sync-dependencies.ts && tsx ../../scripts/generate-icons.ts outlined astro && tsx ../../scripts/generate-exports.ts outlined astro && pnpm run build:dist",
    "build:dev": "pnpm run clean && tsx ../../scripts/sync-dependencies.ts && NODE_ENV=development tsx ../../scripts/generate-icons.ts outlined astro && tsx ../../scripts/generate-exports.ts outlined astro && pnpm run build:dist",
    "build:dist": "node ./scripts/build-dist.mjs",
    "clean": "rimraf dist src/icons src/metadata src/index.ts src/index.d.ts src/w*.ts src/w*.d.ts",
    "test": "echo \"No tests yet\"",
    "lint": "cd ../.. && eslint packages/astro/src --ext .ts --report-unused-disable-directives-severity off"
  },
  "keywords": [
    "astro",
    "icons",
    "material-symbols",
    "components",
    "svg"
  ],
  "author": "h-s-h-r",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/k-s-h-r/material-symbols-svg.git",
    "directory": "packages/astro"
  },
  "bugs": {
    "url": "https://github.com/k-s-h-r/material-symbols-svg/issues"
  },
  "homepage": "https://material-symbols-svg.com",
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@material-symbols/svg-100": "^0.43.0",
    "@material-symbols/svg-200": "^0.43.0",
    "@material-symbols/svg-300": "^0.43.0",
    "@material-symbols/svg-400": "^0.43.0",
    "@material-symbols/svg-500": "^0.43.0",
    "@material-symbols/svg-600": "^0.43.0",
    "@material-symbols/svg-700": "^0.43.0"
  }
}
